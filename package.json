{
  "name": "mood-mixology-cloud-run",
  "version": "1.0.0",
  "description": "Mood Mixology - AI Mixologist on Cloud Run",
  "main": "server.js",
  "scripts": {
    "build": "esbuild index.tsx --bundle --outfile=dist/index.js --loader:.tsx=tsx --loader:.ts=ts --minify --define:process.env.GEMINI_API_KEY=\"'$GEMINI_API_KEY'\"",
    "start": "node server.js",
    "dev": "npm run build && node server.js"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "express": "^4.18.2",
    "firebase": "^12.11.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  }
}
