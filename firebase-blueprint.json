{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "User ID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "displayName": {
          "type": "string",
          "description": "User display name"
        },
        "photoUrl": {
          "type": "string",
          "description": "User photo URL"
        },
        "city": {
          "type": "string",
          "description": "User city"
        },
        "country": {
          "type": "string",
          "description": "User country"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the user profile was created"
        },
        "updatedAt": {
          "type": "timestamp",
          "description": "When the user profile was last updated"
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Cocktail": {
      "title": "Cocktail",
      "description": "A generated cocktail recipe",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The ID of the user who generated this cocktail"
        },
        "name": {
          "type": "string",
          "description": "Name of the cocktail"
        },
        "description": {
          "type": "string",
          "description": "Description of the cocktail"
        },
        "ingredients": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of ingredients"
        },
        "instructions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Step by step instructions"
        },
        "glassware": {
          "type": "string",
          "description": "Recommended glass type"
        },
        "garnish": {
          "type": "string",
          "description": "Recommended garnish"
        },
        "visualPrompt": {
          "type": "string",
          "description": "Prompt used to generate the image"
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the generated image"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the cocktail was generated"
        }
      },
      "required": ["uid", "name", "description", "ingredients", "instructions", "glassware", "garnish", "visualPrompt", "imageUrl", "createdAt"]
    },
    "CommunityRecipe": {
      "title": "Community Recipe",
      "description": "A cocktail recipe shared with the community",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who shared this cocktail" },
        "authorName": { "type": "string", "description": "Name of the author" },
        "authorPhoto": { "type": "string", "description": "Photo URL of the author" },
        "name": { "type": "string", "description": "Name of the cocktail" },
        "description": { "type": "string", "description": "Description of the cocktail" },
        "ingredients": { "type": "array", "items": { "type": "string" }, "description": "List of ingredients" },
        "instructions": { "type": "array", "items": { "type": "string" }, "description": "Step by step instructions" },
        "glassware": { "type": "string", "description": "Recommended glass type" },
        "garnish": { "type": "string", "description": "Recommended garnish" },
        "visualPrompt": { "type": "string", "description": "Prompt used to generate the image" },
        "imageUrl": { "type": "string", "format": "uri", "description": "URL of the generated image" },
        "averageRating": { "type": "number", "description": "Average rating of the recipe" },
        "reviewCount": { "type": "number", "description": "Total number of reviews" },
        "createdAt": { "type": "timestamp", "description": "When the cocktail was shared" }
      },
      "required": ["uid", "authorName", "authorPhoto", "name", "description", "ingredients", "instructions", "glassware", "garnish", "visualPrompt", "imageUrl", "averageRating", "reviewCount", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a community recipe",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID of the reviewer" },
        "authorName": { "type": "string", "description": "Name of the reviewer" },
        "authorPhoto": { "type": "string", "description": "Photo URL of the reviewer" },
        "rating": { "type": "number", "description": "Rating from 1 to 5" },
        "comment": { "type": "string", "description": "Review comment" },
        "createdAt": { "type": "timestamp", "description": "When the review was created" },
        "updatedAt": { "type": "timestamp", "description": "When the review was last updated" }
      },
      "required": ["uid", "authorName", "authorPhoto", "rating", "comment", "createdAt", "updatedAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user",
      "type": "object",
      "properties": {
        "type": { "type": "string", "description": "Type of notification" },
        "recipeId": { "type": "string", "description": "ID of the recipe" },
        "recipeName": { "type": "string", "description": "Name of the recipe" },
        "reviewerName": { "type": "string", "description": "Name of the reviewer" },
        "rating": { "type": "number", "description": "Rating given" },
        "createdAt": { "type": "timestamp", "description": "When the notification was created" },
        "read": { "type": "boolean", "description": "Whether the notification has been read" }
      },
      "required": ["type", "recipeId", "recipeName", "reviewerName", "rating", "createdAt", "read"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profiles"
    },
    "users/{userId}/cocktails/{cocktailId}": {
      "schema": {
        "$ref": "#/entities/Cocktail"
      },
      "description": "Stores cocktails generated by the user"
    },
    "users/{userId}/notifications/{notificationId}": {
      "schema": {
        "$ref": "#/entities/Notification"
      },
      "description": "Stores notifications for the user"
    },
    "community_recipes/{recipeId}": {
      "schema": {
        "$ref": "#/entities/CommunityRecipe"
      },
      "description": "Stores community shared recipes"
    },
    "community_recipes/{recipeId}/reviews/{userId}": {
      "schema": {
        "$ref": "#/entities/Review"
      },
      "description": "Stores reviews for community recipes"
    }
  }
}
